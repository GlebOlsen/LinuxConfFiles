#Api2

Set ThicknessHint = "22px"

include("cpu.source")
include("memory.source")

# Panel layout

layout {

  mirror = "*"
  layer = "top"
  bar_id = "bar-0"

  # Window / workspace indicator
  taskbar {
    rows = 1
    css = "* { -GtkWidget-hexpand: true; -FlowGrid-column-homogeneous: true; }"
    labels = false
    group = pager
    group.icons = true
    group.labels = false
    sort = true
  }

  # CPU graph (min 100px via CSS)
  chart "cpu" {
    interval = 1000
    style = "cpu"
    value = XCpuUtilization
    tooltip = "CPU: " + Str(XCpuUtilization*100, 0) + "%"
  }

  # Memory usage text in GiB (no graph)
  label "mem" {
    interval = 2000
    style = "mem"
    value = Str((XMemTotal - XMemFree - XMemCache - XMemBuff) / 1048576, 1) + " GiB"
    tooltip = "Memory: " + Str(XMemUtilization*100, 0) + "%"
  }

  widget "volume.widget" {
    simple_icon = True
  }

  widget "network.widget"

  widget "battery.widget" {
    device = 'BAT0'
    simple_icon = True
  }

  widget "clock.widget" {
    time_format = "%H:%M"
    tooltip_format = "%H:%M\n%x"
    week_starts_on_sunday = false
    reset_on_popup = false
  }

  tray {
    rows = 1
    css = "grid { -GtkWidget-column-homogeneous: false; }"
  }
}

#CSS
@define-color theme_text_color white;
@define-color theme_bg_color black;
@define-color theme_fg_color white;
@define-color borders rgba(256,256,256,0.3);

window#sfwbar {
  -GtkWidget-direction: top;
  background-color: rgba(0,0,0,0.65);
}

grid {
  padding: 0px;
  margin: 0px;
}

label {
  font-family: Sans;
  font-size: 12px;
  color: @theme_text_color;
  text-shadow: none;
  padding: 0 6px;
}

* {
  -GtkWidget-vexpand: true;
}

tooltip {
  background-color: @theme_bg_color;
}

image {
  min-width: 14px;
  min-height: 14px;
  box-shadow: none;
  border: none;
  border-image: none;
  background-image: none;
  background: none;
  color: @theme_fg_color;
  -gtk-icon-shadow: none;
}

button {
  box-shadow: none;
  border-image: none;
  background-image: none;
  background: none;
  outline-style: none;
  padding: 0 4px;
  border: none;
}

chart#cpu {
  min-width: 100px;
  margin: 3px 6px;
  background: rgba(127,127,127,0.3);
  border: 1px solid @borders;
  border-radius: 3px;
  color: red;
}

label#mem {
  min-width: 55px;
}

/* taskbar */
grid#taskbar_pager {
  padding: 0 3px;
  border-radius: 4px;
  border: solid rgba(119,119,119,0.3) 1px;
}

button#taskbar_item image {
  min-width: 14px;
  min-height: 14px;
}

button#taskbar_item {
  padding: 0 4px;
  border-radius: 4px;
  background-color: rgba(119,119,119,0.15);
  border-color: rgba(119,119,119,0.3);
  -GtkWidget-hexpand: false;
}

button#taskbar_item.focused {
  background-color: rgba(255,255,255,0.2);
  border-color: rgba(255,255,255,0.4);
}

button#taskbar_item:hover {
  background-color: rgba(176,176,176,0.22);
  border-color: rgba(234,234,234,0.44);
}

/* tray */
button#tray_item {
  padding: 0 1px 0 0;
  border: none;
  margin: 0;
  -GtkWidget-valign: center;
}

button#tray_item.passive {
  -GtkWidget-visible: false;
}

.module image,
button#module image {
  padding: 0;
  margin: 0;
  min-width: 16px;
  min-height: 16px;
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  color: @theme_fg_color;
  -ScaleImage-color: @theme_text_color;
  -ScaleImage-symbolic: true;
}

.module,
button#module {
  border: none;
  padding: 0 4px;
  margin: 0;
  -GtkWidget-vexpand: true;
  -GtkWidget-valign: center;
}
