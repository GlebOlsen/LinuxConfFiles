#Api2

# Force dark GTK theme so icons/text contrast on dark bar
Theme = "Adwaita-dark"
IconTheme = "Adwaita"

Set ThicknessHint = "16px"

include("cpu.source")
include("memory.source")
include("winops.widget")

# Panel layout

layout {

  mirror = "*"
  layer = "top"
  bar_id = "bar-0"

  # appmenu module (launcher)
  widget "startmenu.widget"

  # Workspaces on the left
  pager {
    rows = 1
    pins = "1","2","3","4"
    preview = true
    primary_axis = rows
    action[Drag] = WorkspaceActivate()
  }

  # Window list (icons only, sized to content)
  taskbar {
    rows = 1
    labels = false
    icons = true
    group = false
    sort = true
    tooltips = true
    action[RightClick] = Menu("winops")
    action[Drag] = Focus()
  }

  # Spacer pushes right-side widgets to the edge
  label {
    css = "* { -GtkWidget-hexpand: true; }"
    value = ""
  }

  # CPU graph (100px)
  chart "cpu" {
    interval = 1000
    style = "cpu"
    value = XCpuUtilization
    tooltip = "CPU: " + Str(XCpuUtilization*100, 0) + "%"
  }

  # Memory usage text in GiB
  label "mem" {
    interval = 2000
    style = "mem"
    value = Str((XMemTotal - XMemFree - XMemCache - XMemBuff) / 1048576, 1) + " GiB"
    tooltip = "Memory: " + Str(XMemUtilization*100, 0) + "%"
  }

  # System tray
  tray {
    rows = 1
    css = "grid { -GtkWidget-column-homogeneous: false; }"
  }

  # pulsectl / alsactl module
  widget "volume.widget" {
    simple_icon = True
  }

  # bluez module
  widget "bluez.widget" {
    scan_timeout = 20
  }

  # pipewire module (mic/cam in-use indicator)
  widget "privacy.widget" {
    audio_icon = "audio-input-microphone"
    video_icon = "camera-web"
  }

  # battery (wbar variant - shows percentage as text)
  widget "wbar-battery.widget"

  # brightness control
  widget "backlight.widget" {
    step = 5
    max_brightness = 100
    min_brightness = 30
  }

  # ncenter module (notifications - disabled to avoid clash)
  widget "ncenter.widget" {
    disable = true
  }

  # Custom clock label - updates every second so seconds tick
  label "clock" {
    interval = 1000
    value = Time("%H:%M:%S  %b. %a, %-d/%m/%y")
    tooltip = Time("%H:%M:%S\n%A, %B %-d %Y")
  }
}

#CSS

/* Override Adwaita-dark gray bg for popups/menus -> dark green */
@define-color theme_bg_color rgba(0, 40, 20, 0.95);
@define-color theme_base_color rgba(0, 40, 20, 0.95);
@define-color theme_fg_color #ffffff;
@define-color theme_text_color #ffffff;

window#sfwbar {
  background-color: rgba(0, 40, 20, 0.7);
}

popover, menu, tooltip, window {
  background-color: rgba(0, 40, 20, 0.95);
  color: #ffffff;
}

label {
  color: #ffffff;
}

chart#cpu {
  min-width: 100px;
}

/* Icons: bigger + centered (match upstream default sizing) */
button#taskbar_item image {
  min-width: calc(@bar_thickness * 0.9);
  min-height: calc(@bar_thickness * 0.9);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  -ScaleImage-symbolic: false;
}

button#taskbar_item {
  padding: 0 2px;
  -GtkWidget-valign: center;
}

button#tray_item image {
  min-width: calc(@bar_thickness * 0.9);
  min-height: calc(@bar_thickness * 0.9);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  padding: 0 2px;
}

.module image,
button#module image {
  min-width: calc(@bar_thickness * 0.9);
  min-height: calc(@bar_thickness * 0.9);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
}
