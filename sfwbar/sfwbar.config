#Api2

# Force dark GTK theme so icons/text contrast on dark bar
Theme = "Adwaita-dark"
IconTheme = "Adwaita"

Set ThicknessHint = "22px"

include("cpu.source")
include("memory.source")

# Panel layout

layout {

  mirror = "*"
  layer = "top"
  bar_id = "bar-0"

  # appmenu module
  widget "startmenu.widget"

  # Window / workspace indicator
  taskbar {
    rows = 1
    css = "* { -GtkWidget-hexpand: true; -FlowGrid-column-homogeneous: true; }"
    labels = false
    group = pager
    group.icons = true
    group.labels = false
    sort = true
  }

  # CPU graph
  chart "cpu" {
    interval = 1000
    style = "cpu"
    value = XCpuUtilization
    tooltip = "CPU: " + Str(XCpuUtilization*100, 0) + "%"
  }

  # Memory usage text in GiB
  label "mem" {
    interval = 2000
    style = "mem"
    value = Str((XMemTotal - XMemFree - XMemCache - XMemBuff) / 1048576, 1) + " GiB"
    tooltip = "Memory: " + Str(XMemUtilization*100, 0) + "%"
  }

  # System tray
  tray {
    rows = 1
    css = "grid { -GtkWidget-column-homogeneous: false; }"
  }

  # pulsectl / alsactl module
  widget "volume.widget" {
    simple_icon = True
  }

  # bluez module
  widget "bluez.widget" {
    scan_timeout = 20
  }

  # network module (NM/iwd-aware)
  widget "network.widget"

  # wifi-nm / wifi-iwd module
  widget "wifi.widget"

  # pipewire module (mic/cam in-use indicator)
  widget "privacy.widget" {
    audio_icon = "audio-input-microphone"
    video_icon = "camera-web"
  }

  # battery (upower-based, no module needed)
  widget "battery.widget" {
    device = 'BAT0'
    simple_icon = True
  }

  # idleinhibit module
  widget "idleinhibit.widget" {
    icon_active = "icons/misc/lock-symbolic"
    icon_inactive = "icons/misc/unlock-symbolic"
  }

  # mpd module
  widget "mpd.widget" {
    simple_icon = false
  }

  # xkbmap module
  widget "language.widget"

  # ncenter module (notifications - disabled by default to avoid clash)
  widget "ncenter.widget" {
    disable = true
  }

  widget "clock.widget" {
    time_format = "%H:%M"
    tooltip_format = "%H:%M\n%x"
    week_starts_on_sunday = false
    reset_on_popup = false
  }
}

#CSS
window#sfwbar {
  background-color: rgba(0, 40, 20, 0.7);
}

label {
  color: #ffffff;
}
