#Api2

Theme = "Adwaita-dark"
IconTheme = "Adwaita"

include("cpu.source")
include("memory.source")
include("winops.widget")
include("cal.widget")

# Panel layout

layout {

  mirror = "*"
  layer = "top"
  edge = "top"
  bar_id = "bar-0"

  # Workspaces on the left
  pager {
    rows = 1
    pins = "1","2","3","4"
    preview = false
    primary_axis = rows
    action[Drag] = WorkspaceActivate()
  }

  # Window list (icons only)
  taskbar {
    rows = 1
    labels = false
    icons = true
    group = false
    sort = true
    tooltips = true
    action[RightClick] = Menu("winops")
    action[Drag] = Focus()
  }

  # Spacer pushes right-side widgets to the edge
  label {
    css = "* { -GtkWidget-hexpand: true; }"
    value = ""
  }

  # CPU graph (100px)
  chart "cpu" {
    interval = 1000
    style = "cpu"
    value = XCpuUtilization
    tooltip = "CPU: " + Str(XCpuUtilization*100, 0) + "%"
  }

  # Memory usage text in GiB
  label "mem" {
    interval = 2000
    style = "mem"
    value = Str((XMemTotal - XMemFree - XMemCache - XMemBuff) / 1048576, 1) + " GiB"
    tooltip = "Memory: " + Str(XMemUtilization*100, 0) + "%"
  }

  # System tray
  tray {
    rows = 1
    css = "grid { -GtkWidget-column-homogeneous: false; }"
  }

  # pulsectl / alsactl module
  widget "volume.widget" {
    simple_icon = True
  }

  # pipewire module (mic/cam in-use indicator)
  widget "privacy.widget" {
    audio_icon = "audio-input-microphone"
    video_icon = "camera-web"
  }

  # battery: simple icon variant (autodetected device)
  widget "battery.widget" {
    simple_icon = True
  }

  # brightness control
  widget "backlight.widget" {
    step = 5
    max_brightness = 100
    min_brightness = 30
  }

  # ncenter module (notifications - disabled to avoid clash)
  widget "ncenter.widget" {
    disable = true
  }

  # Custom clock label - 1s tick, click pops calendar
  label "clock" {
    interval = 1000
    value = Time("%H:%M:%S  %b. %a, %-d/%m/%y")
    tooltip = Time("%H:%M:%S\n%A, %B %-d %Y")
    action = PopUp("Xcal")
  }
}

#CSS

/* Compact bar height (GTK sizes window to content; shrink content) */
window#sfwbar {
  background-color: rgba(0, 40, 20, 0.7);
  min-height: 0;
}

window#sfwbar grid,
window#sfwbar button,
window#sfwbar label {
  min-height: 0;
  padding: 0 2px;
  margin: 0;
}

window#sfwbar image {
  min-width: 18px;
  min-height: 18px;
  padding: 0;
  margin: 0;
}

label {
  color: #ffffff;
  font-size: 12px;
}

chart#cpu {
  min-width: 100px;
}

/* Pager: highlight current workspace */
button#pager_item.focused {
  background-color: rgba(255, 255, 255, 0.25);
  color: #c6ff6a;
}

button#pager_item.focused label {
  color: #c6ff6a;
  font-weight: bold;
}
