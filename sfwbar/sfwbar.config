#Api2

Theme = "Adwaita-dark"
IconTheme = "Adwaita"

Set ThicknessHint = "16px"

include("cpu.source")
include("memory.source")
include("winops.widget")
include("cal.widget")

# Panel layout

layout {

  mirror = "*"
  layer = "top"
  bar_id = "bar-0"

  # appmenu module (launcher)
  widget "startmenu.widget"

  # Workspaces on the left
  pager {
    rows = 1
    pins = "1","2","3","4"
    preview = true
    primary_axis = rows
    action[Drag] = WorkspaceActivate()
  }

  # Window list (icons only, sized to content)
  taskbar {
    rows = 1
    labels = false
    icons = true
    group = false
    sort = true
    tooltips = true
    action[RightClick] = Menu("winops")
    action[Drag] = Focus()
  }

  # Spacer pushes right-side widgets to the edge
  label {
    css = "* { -GtkWidget-hexpand: true; }"
    value = ""
  }

  # playerctl (MPRIS) — prev / play-pause / next + track label
  button {
    value = "media-skip-backward-symbolic"
    class = "module"
    tooltip = "Previous"
    action = Exec("playerctl previous")
  }
  button {
    value = "media-playback-start-symbolic"
    class = "module"
    tooltip = "Play / Pause"
    action = Exec("playerctl play-pause")
  }
  button {
    value = "media-skip-forward-symbolic"
    class = "module"
    tooltip = "Next"
    action = Exec("playerctl next")
  }
  label "player" {
    interval = 2000
    value = ExecRead("playerctl metadata --format '{{title}} — {{artist}}' 2>/dev/null | cut -c1-40")
    tooltip = ExecRead("playerctl metadata --format '{{artist}} — {{album}} — {{title}}' 2>/dev/null")
  }

  # CPU graph (100px)
  chart "cpu" {
    interval = 1000
    style = "cpu"
    value = XCpuUtilization
    tooltip = "CPU: " + Str(XCpuUtilization*100, 0) + "%"
  }

  # Memory usage text in GiB
  label "mem" {
    interval = 2000
    style = "mem"
    value = Str((XMemTotal - XMemFree - XMemCache - XMemBuff) / 1048576, 1) + " GiB"
    tooltip = "Memory: " + Str(XMemUtilization*100, 0) + "%"
  }

  # System tray
  tray {
    rows = 1
    css = "grid { -GtkWidget-column-homogeneous: false; }"
  }

  # pulsectl / alsactl module
  widget "volume.widget" {
    simple_icon = True
  }

  # bluez module
  widget "bluez.widget" {
    scan_timeout = 20
  }

  # pipewire module (mic/cam in-use indicator)
  widget "privacy.widget" {
    audio_icon = "audio-input-microphone"
    video_icon = "camera-web"
  }

  # battery (default svg from t2/w10 - dynamic charge gradient)
  widget "battery.widget" {
    simple_icon = False
  }

  # brightness control
  widget "backlight.widget" {
    step = 5
    max_brightness = 100
    min_brightness = 30
  }

  # ncenter module (notifications - disabled to avoid clash)
  widget "ncenter.widget" {
    disable = true
  }

  # Custom clock label - 1s tick, click pops calendar
  label "clock" {
    interval = 1000
    value = Time("%H:%M:%S  %b. %a, %-d/%m/%y")
    tooltip = Time("%H:%M:%S\n%A, %B %-d %Y")
    action = PopUp("Xcal")
  }
}

#CSS

window#sfwbar {
  background-color: rgba(0, 40, 20, 0.7);
}

label {
  color: #ffffff;
  font-family: Sans;
  font-size: calc(@bar_thickness * 0.7);
}

chart#cpu {
  min-width: 100px;
}

/* Icons: bigger + centered (match upstream default sizing) */
button#taskbar_item image {
  min-width: calc(@bar_thickness * 0.9);
  min-height: calc(@bar_thickness * 0.9);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  -ScaleImage-symbolic: false;
}

button#taskbar_item {
  padding: 0 2px;
  -GtkWidget-valign: center;
}

button#tray_item image {
  min-width: calc(@bar_thickness * 0.9);
  min-height: calc(@bar_thickness * 0.9);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
  padding: 0 2px;
}

.module image,
button#module image {
  min-width: calc(@bar_thickness * 0.9);
  min-height: calc(@bar_thickness * 0.9);
  -GtkWidget-valign: center;
  -GtkWidget-vexpand: true;
}
