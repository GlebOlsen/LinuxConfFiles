#Api2

# Force dark GTK theme so icons/text contrast on dark bar
Theme = "Adwaita-dark"
IconTheme = "Adwaita"

Set ThicknessHint = "22px"

include("cpu.source")
include("memory.source")
include("winops.widget")

# Panel layout

layout {

  mirror = "*"
  layer = "top"
  bar_id = "bar-0"

  # appmenu module
  widget "startmenu.widget"

  # Workspaces on the left
  pager {
    rows = 1
    pins = "1","2","3","4"
    preview = true
    primary_axis = rows
    action[Drag] = WorkspaceActivate()
  }

  widget "showdesktop.widget"

  # Window list
  taskbar {
    rows = 1
    css = "* { -GtkWidget-hexpand: true; -FlowGrid-column-homogeneous: true; }"
    labels = false
    group = false
    icons = true
    sort = true
    action[RightClick] = Menu("winops")
    action[Drag] = Focus()
  }

  # CPU graph (100px)
  chart "cpu" {
    interval = 1000
    style = "cpu"
    value = XCpuUtilization
    tooltip = "CPU: " + Str(XCpuUtilization*100, 0) + "%"
  }

  # Memory usage text in GiB
  label "mem" {
    interval = 2000
    style = "mem"
    value = Str((XMemTotal - XMemFree - XMemCache - XMemBuff) / 1048576, 1) + " GiB"
    tooltip = "Memory: " + Str(XMemUtilization*100, 0) + "%"
  }

  # System tray
  tray {
    rows = 1
    css = "grid { -GtkWidget-column-homogeneous: false; }"
  }

  # pulsectl / alsactl module
  widget "volume.widget" {
    simple_icon = True
  }

  # bluez module
  widget "bluez.widget" {
    scan_timeout = 20
  }

  # network module (NM/iwd-aware)
  widget "network.widget"

  # wifi-nm / wifi-iwd module
  widget "wifi.widget"

  # pipewire module (mic/cam in-use indicator)
  widget "privacy.widget" {
    audio_icon = "audio-input-microphone"
    video_icon = "camera-web"
  }

  # battery (upower-based)
  widget "battery.widget" {
    device = 'BAT0'
    simple_icon = True
  }

  # upower devices (mouse/headset batteries etc)
  widget "upower.widget"

  # brightness control
  widget "backlight.widget" {
    step = 5
    max_brightness = 100
    min_brightness = 30
  }

  # ncenter module (notifications - disabled to avoid clash)
  widget "ncenter.widget" {
    disable = true
  }

  # session menu (logout / reboot / shutdown)
  widget "session.widget" {
    session_actions = [
      ["system-lock-screen", "Lock", "loginctl lock-session"],
      ["system-log-out", "Logout", "loginctl terminate-user $USER"],
      ["system-reboot", "Reboot", "systemctl reboot"],
      ["system-shutdown", "Shutdown", "systemctl poweroff"]
    ]
  }

  widget "clock.widget" {
    time_format = "%H:%M"
    tooltip_format = "%H:%M\n%x"
    week_starts_on_sunday = false
    reset_on_popup = false
  }
}

#CSS
window#sfwbar {
  background-color: rgba(0, 40, 20, 0.7);
}

label {
  color: #ffffff;
}

chart#cpu {
  min-width: 100px;
}
